# Public URL of the Wolfathon server Worker (the overlay API).
# In production this is your deployed server Worker URL.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Cloudflare Access (Zero Trust) — gates /control and /api/trpc ---
# Your Access team domain, e.g. myteam.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=
# The Access application's Audience (AUD) tag.
CF_ACCESS_AUD=
# Leave "false" in production. Set "true" ONLY for local dev to skip Access.
ACCESS_DISABLED=false
