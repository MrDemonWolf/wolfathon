# Public URL of the Wolfathon server Worker (the overlay API).
# Production: https://wolfathon-api.mrdemonwolf.workers.dev
# (Infra injects this automatically from the deployed server Worker.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Cloudflare Access (Zero Trust) — gates /control and /api/trpc ---
# Your Access team domain, e.g. myteam.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=
# The Access application's Audience (AUD) tag.
CF_ACCESS_AUD=

# --- Twitch app (OAuth Authorization Code / redirect flow) ---
# From dev.twitch.tv → your app. The app's OAuth Redirect URL must be set to
# <web origin>/api/twitch/callback (e.g. http://localhost:3001/api/twitch/callback
# for dev, https://wolfathon.mrdemonwolf.workers.dev/api/twitch/callback in prod).
# Keep that callback path OUTSIDE the Cloudflare Access app.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
#
# NOTE: the Access bypass is automatic — `bun run dev` (alchemy dev) disables
# Access locally, and every real deploy ENFORCES it. There is no ACCESS_DISABLED
# knob to set here, so the control panel can never ship unprotected.
