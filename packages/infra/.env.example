# Encrypts local Alchemy deploy state. Change to a strong, private secret.
ALCHEMY_PASSWORD=please-change-this

# Optional. Production web origin; also the default CORS origin for the API.
# Defaults to https://wolfathon.mrdemonwolf.workers.dev — only set to override.
# WEB_URL=

# Cloudflare credentials used at deploy time.
# Either run `bunx wrangler login`, or set a scoped API token + account id:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# --- Cloudflare Access — baked into the web Worker at deploy time ---
# Access team domain, e.g. myteam.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=
# The Access application's Audience (AUD) tag for the web app.
CF_ACCESS_AUD=
#
# Access enforcement is automatic: a real deploy always enforces it, local
# `alchemy dev` always bypasses it. No ACCESS_DISABLED flag to manage.
