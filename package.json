{
	"name": "wolfathon",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"@cloudflare/workers-types": "^4.20251213.0",
			"hono": "^4.8.2",
			"@trpc/server": "^11.16.0",
			"alchemy": "^0.91.2",
			"wrangler": "^4.77.0",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.6",
			"react-dom": "^19.2.6",
			"sonner": "^2.0.5",
			"@trpc/client": "^11.16.0",
			"@types/react": "^19.2.15",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"check": "eslint . && prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "bun test packages/api/src",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:generate": "turbo -F @wolfathon/db db:generate",
		"deploy": "turbo -F @wolfathon/infra deploy",
		"destroy": "turbo -F @wolfathon/infra destroy"
	},
	"dependencies": {
		"@wolfathon/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.2",
		"@wolfathon/config": "workspace:*",
		"@types/node": "^22.13.14",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-unused-imports": "^4.4.1",
		"prettier": "^3.8.1",
		"turbo": "^2.9.16",
		"typescript": "catalog:",
		"typescript-eslint": "^8.58.0"
	},
	"packageManager": "bun@1.3.14"
}
